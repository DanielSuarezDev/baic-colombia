---
import "animate.css";
---

<header
  id="header"
  class="w-full z-50 fixed flex justify-between items-center px-6 md:px-12 py-4 transition-all duration-300 ease-in-out menu-header"
>
  <a href="/" class="z-50 shrink-0">
    <img
      src={"./logo.webp"}
      alt="Logo Baic"
      class="h-8 md:h-10 transition-all duration-300 transform hover:scale-105"
      id="header-logo"
    />
  </a>

  <div class="flex items-center gap-4 lg:gap-8 grow justify-end">
    <nav
      id="menu"
      class="fixed inset-0 z-[60] lg:bg-transparent lg:static lg:flex lg:flex-row lg:items-center lg:gap-8 hidden h-screen lg:h-auto w-full lg:w-auto p-12 lg:p-0 flex-col justify-center animate-fade-in"
    >
      <button
        id="menu-close"
        class="absolute lg:hidden top-8 right-8 p-2 text-gray-500 hover:text-black dark:hover:text-white transition-colors"
      >
        <img class="w-8 dark:invert" src="./x.png" alt="Close Menu" />
      </button>

      <a href="#about" class="nav-link">SOBRE NOSOTROS</a>
      <a href="#data" class="nav-link">EU5</a>
      <a href="#contact" class="nav-link contact-btn">MÁS INFORMACIÓN</a>
    </nav>

    <!-- Theme Switch -->
    <div class="flex items-center gap-2 z-50">
      <button
        id="theme-toggle"
        class="relative inline-flex h-8 w-14 items-center rounded-full bg-gray-200 dark:bg-gray-700 transition-colors duration-300 focus:outline-none group shadow-inner"
        aria-label="Toggle Theme"
      >
        <span
          id="theme-toggle-dot"
          class="inline-block h-6 w-6 transform rounded-full bg-white dark:bg-[#EF4444] shadow-md transition-transform duration-300 translate-x-1 dark:translate-x-7 flex items-center justify-center"
        >
          <!-- Sun Icon (Light Mode) -->
          <svg
            id="theme-toggle-light-icon"
            class="w-4 h-4 text-orange-400 block dark:hidden"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
            ></path>
          </svg>
          <!-- Moon Icon (Dark Mode) -->
          <svg
            id="theme-toggle-dark-icon"
            class="w-4 h-4 text-white hidden dark:block"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
            ></path>
          </svg>
        </span>
      </button>
    </div>

    <div class="lg:hidden z-50">
      <button id="menu-open" class="p-2 group">
        <div class="space-y-1.5 flex flex-col items-end">
          <span
            class="block w-6 h-0.5 bg-white burger-line transition-all group-hover:w-8"
          ></span>
          <span class="block w-8 h-0.5 bg-white burger-line transition-all"
          ></span>
          <span
            class="block w-5 h-0.5 bg-white burger-line transition-all group-hover:w-8"
          ></span>
        </div>
      </button>
    </div>
  </div>
</header>

<style>
  .menu-header {
    background: transparent;
    color: white;
  }

  .scrolled {
    @apply bg-white/95 dark:bg-[#020617]/90 backdrop-blur-xl border-b border-black/5 dark:border-white/5 py-3 md:py-4 shadow-xl;
  }

  .scrolled .nav-link {
    @apply text-gray-700 dark:text-gray-200;
  }
  .scrolled .burger-line {
    @apply bg-black dark:bg-white;
  }
  .scrolled #theme-toggle {
    @apply text-black dark:text-white;
  }

  .nav-link {
    @apply text-sm font-semibold tracking-wider text-white transition-all duration-300 relative py-2 uppercase no-underline hover:text-red-500;
  }

  .contact-btn {
    @apply bg-red-500 text-white px-8 py-3 rounded-full hover:bg-black dark:hover:bg-red-400 transform hover:-translate-y-1 transition-all duration-300 font-bold uppercase !text-white !bg-red-500 !no-underline;
  }

  @media (max-width: 1023px) {
    .nav-link {
      @apply text-2xl mb-6 text-black dark:text-white text-center;
    }
  }
</style>

<script>
  const setupThemeAndMenu = () => {
    // Theme toggle
    const themeToggleBtn = document.getElementById("theme-toggle");

    if (themeToggleBtn) {
      themeToggleBtn.addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      });
    }

    // Menu toggle
    const header = document.getElementById("header");
    const menu = document.getElementById("menu");
    const openBtn = document.getElementById("menu-open");
    const closeBtn = document.getElementById("menu-close");
    const body = document.getElementById("body");

    const toggleMenu = (isOpen: boolean) => {
      if (isOpen) {
        menu?.classList.remove("hidden");
        menu?.classList.add("flex");
        body?.classList.add("overflow-hidden");
      } else {
        menu?.classList.add("hidden");
        menu?.classList.remove("flex");
        body?.classList.remove("overflow-hidden");
      }
    };

    if (openBtn) openBtn.onclick = () => toggleMenu(true);
    if (closeBtn) closeBtn.onclick = () => toggleMenu(false);

    window.onscroll = () => {
      if (window.scrollY > 50) {
        header?.classList.add("scrolled");
      } else {
        header?.classList.remove("scrolled");
      }
    };
  };

  setupThemeAndMenu();
  document.addEventListener("astro:after-swap", setupThemeAndMenu);
</script>
