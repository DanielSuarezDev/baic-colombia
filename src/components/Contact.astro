<section id="contact" class="py-24 bg-gray-50 dark:bg-slate-950 transition-colors duration-500 relative overflow-hidden text-black dark:text-white">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-red-500/5 blur-[160px] rounded-full pointer-events-none"></div>

  <div class="container mx-auto px-6 md:px-12 relative z-10">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-[#EF4444] text-sm font-bold tracking-[0.2em] mb-4 uppercase">¿LISTO PARA EL FUTURO?</h2>
        <h3 class="text-5xl md:text-6xl font-black font-tomaso mb-6 text-black dark:text-white uppercase uppercase">CONTÁCTANOS</h3>
        <p class="text-xl text-gray-400 dark:text-gray-400 font-light max-w-2xl mx-auto">
          Déjanos tus datos y un asesor experto se pondrá en contacto contigo para brindarte toda la información que necesitas.
        </p>
      </div>

      <div class="bg-white dark:bg-slate-900 p-8 md:p-12 rounded-[3rem] border border-gray-100 dark:border-white/10 shadow-2xl transition-all duration-500">
        <form class="space-y-8" action="#" method="POST">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Name -->
            <div class="space-y-2">
              <label class="text-sm font-semibold text-gray-400 dark:text-gray-500 ml-4 uppercase tracking-wider">Nombre Completo</label>
              <input
                class="w-full px-6 py-4 bg-gray-50 dark:bg-slate-950 border border-gray-200 dark:border-white/5 rounded-2xl outline-none focus:border-[#EF4444] dark:focus:border-[#EF4444] focus:bg-white dark:focus:bg-slate-800 transition-all text-black dark:text-white placeholder:text-gray-300 dark:placeholder:text-gray-600"
                type="text"
                placeholder="Ej: Samuel Suarez"
                required
              />
            </div>
            
            <!-- Email -->
            <div class="space-y-2">
              <label class="text-sm font-semibold text-gray-400 dark:text-gray-500 ml-4 uppercase tracking-wider">Correo Electrónico</label>
              <input
                class="w-full px-6 py-4 bg-gray-50 dark:bg-slate-950 border border-gray-200 dark:border-white/5 rounded-2xl outline-none focus:border-[#EF4444] dark:focus:border-[#EF4444] focus:bg-white dark:focus:bg-slate-800 transition-all text-black dark:text-white placeholder:text-gray-300 dark:placeholder:text-gray-600"
                type="email"
                placeholder="correo@ejemplo.com"
                required
              />
            </div>

            <!-- Phone -->
            <div class="space-y-2">
              <label class="text-sm font-semibold text-gray-400 dark:text-gray-500 ml-4 uppercase tracking-wider">Teléfono</label>
              <input
                class="w-full px-6 py-4 bg-gray-50 dark:bg-slate-950 border border-gray-200 dark:border-white/5 rounded-2xl outline-none focus:border-[#EF4444] dark:focus:border-[#EF4444] focus:bg-white dark:focus:bg-slate-800 transition-all text-black dark:text-white placeholder:text-gray-300 dark:placeholder:text-gray-600"
                type="tel"
                placeholder="+57 300 000 0000"
                required
              />
            </div>

            <!-- Contact Method -->
            <div class="space-y-2">
              <label class="text-sm font-semibold text-gray-400 dark:text-gray-500 ml-4 uppercase tracking-wider">Preferencia de Contacto</label>
              <div class="relative">
                <select
                  class="w-full px-6 py-4 bg-gray-50 dark:bg-slate-950 border border-gray-200 dark:border-white/5 rounded-2xl outline-none focus:border-[#EF4444] dark:focus:border-[#EF4444] focus:bg-white dark:focus:bg-slate-800 transition-all text-black dark:text-white appearance-none cursor-pointer"
                  required
                >
                  <option value="" disabled selected class="dark:bg-slate-900">¿Cómo prefieres que te contactemos?</option>
                  <option value="whatsapp" class="dark:bg-slate-900">WhatsApp</option>
                  <option value="llamada" class="dark:bg-slate-900">Llamada telefónica</option>
                  <option value="correo" class="dark:bg-slate-900">Correo electrónico</option>
                </select>
                <div class="absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-gray-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </div>
            </div>
          </div>

          <!-- Checkbox & Captcha -->
          <div class="flex flex-col md:flex-row items-center justify-between gap-8 pt-4">
            <label class="flex items-center gap-4 cursor-pointer group">
              <div class="relative">
                <input type="checkbox" id="check" class="peer sr-only" />
                <div class="w-6 h-6 border-2 border-gray-200 dark:border-white/10 rounded-lg group-hover:border-[#EF4444] transition-colors peer-checked:bg-[#EF4444] peer-checked:border-[#EF4444]"></div>
                <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 h-6 w-6 text-white scale-0 peer-checked:scale-75 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-lg text-gray-500 dark:text-gray-400 group-hover:text-black dark:group-hover:text-white transition-colors">Quiero agendar un <span class="font-bold text-[#EF4444]">Test Drive</span></span>
            </label>

            <div class="g-recaptcha" data-sitekey="6Ld-sHAqAAAAAKsiYBnSpKi_kq-REw8kNAqZc7ft"></div>
          </div>

          <!-- Submit -->
          <div class="pt-8">
            <button
              type="submit"
              class="w-full py-5 bg-[#EF4444] text-white hover:bg-black dark:hover:bg-red-400 font-bold text-xl rounded-2xl transition-all duration-300 transform hover:scale-[1.01] active:scale-95 shadow-xl hover:shadow-red-500/20"
            >
              ENVIAR SOLICITUD
            </button>
            <p class="text-center text-gray-400 text-xs mt-6">
              Al enviar sus datos, acepta nuestras políticas de tratamiento de datos personales.
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
