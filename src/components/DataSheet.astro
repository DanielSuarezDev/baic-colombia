---
import "animate.css";
---

<section
  id="data"
  class="py-24 bg-white dark:bg-slate-950 px-6 lg:px-0 transition-colors duration-300 relative overflow-hidden"
>
  <!-- Decoration -->
  <div
    class="absolute top-0 right-0 w-96 h-96 bg-gray-100 dark:bg-slate-900 blur-3xl rounded-full -translate-y-1/2 translate-x-1/2"
  >
  </div>

  <div class="container mx-auto px-6 md:px-12">
    <!-- Top Part: Title and Color Picker -->
    <div class="flex flex-col lg:flex-row items-center gap-16 mb-24">
      <div class="lg:w-1/2 text-center lg:text-left">
        <h2
          class="text-[#EF4444] text-sm font-bold tracking-[0.2em] mb-4 uppercase"
        >
          ESPECIFICACIONES
        </h2>
        <h3
          class="text-6xl md:text-8xl font-black mb-10 font-tomaso text-black dark:text-white uppercase"
        >
          EU5
        </h3>
        <p
          class="text-xl text-gray-500 dark:text-gray-400 mb-12 max-w-md mx-auto lg:mx-0 font-light italic"
        >
          Potencia, autonomía y tecnología en cada detalle.
        </p>
        <a
          target="_blank"
          href="./ft.pdf"
          class="inline-flex text-gray-500 dark:text-white items-center gap-3 px-10 py-4 border-2 border-gray-200 hover:border-[#EF4444] hover:bg-[#EF4444]/5 rounded-full transition-all duration-300 font-bold group text-black"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
            ></path>
          </svg>
          DESCARGAR FICHA TÉCNICA
        </a>
      </div>

      <div class="lg:w-1/2 w-full relative">
        <div class="aspect-video relative mb-8">
          <img
            id="red-car"
            class="car-image absolute inset-0 w-full h-full object-contain transition-all duration-700 opacity-0 scale-95 translate-x-8"
            src="./red-car_1.webp"
            alt="Baic EU5 Red"
          />
          <img
            id="white-car"
            class="car-image absolute inset-0 w-full h-full object-contain transition-all duration-700 opacity-100 scale-100"
            src="./white-car.webp"
            alt="Baic EU5 White"
          />
          <img
            id="black-car"
            class="car-image absolute inset-0 w-full h-full object-contain transition-all duration-700 opacity-0 scale-95 translate-x-8"
            src="./black-car.webp"
            alt="Baic EU5 Black"
          />
        </div>

        <div class="flex flex-col items-center gap-4">
          <p class="text-gray-400 text-xs font-bold tracking-widest uppercase">
            Colores disponibles
          </p>
          <div
            class="flex items-center gap-6 p-2 bg-gray-50 rounded-full border border-gray-100"
          >
            <button
              id="white"
              class="color-btn w-8 h-8 bg-white rounded-full border-4 border-transparent hover:scale-110 transition-transform active-color shadow-lg shadow-black/5"
              title="Blanco"></button>
            <button
              id="red"
              class="color-btn w-8 h-8 bg-red-600 rounded-full border-4 border-transparent hover:scale-110 transition-transform shadow-md"
              title="Rojo"></button>
            <button
              id="black"
              class="color-btn w-8 h-8 bg-slate-900 rounded-full border-4 border-transparent hover:scale-110 transition-transform shadow-md"
              title="Negro"></button>
          </div>
        </div>
      </div>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {/* Feature 1 */}
      <div
        class="bg-gray-50 dark:bg-slate-900 p-8 rounded-3xl flex flex-col items-center text-center group hover:bg-white dark:hover:bg-slate-800 hover:shadow-2xl hover:shadow-red-500/10 transition-all duration-500 border border-gray-100 dark:border-white/5"
      >
        <div class="w-full h-48 mb-8 overflow-hidden rounded-2xl">
          <img
            src="./1.webp"
            alt="Comodidad"
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
          />
        </div>
        <h4 class="text-2xl font-bold mb-2 text-black dark:text-white">
          COMODIDAD
        </h4>
        <p
          class="text-[#EF4444] text-sm font-semibold mb-6 uppercase tracking-wider"
        >
          Espacio Premium
        </p>
        <ul
          class="text-gray-600 dark:text-gray-400 space-y-3 text-left w-full font-light"
        >
          <li class="flex items-start gap-2">
            <span class="text-[#EF4444] mt-1">●</span>
            Distancia entre ejes extra larga de 2670 MM
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#EF4444] mt-1">●</span>
            Ajuste ergonómico de 6 posiciones
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#EF4444] mt-1">●</span>
            Baúl de gran volumen: 430 L
          </li>
        </ul>
      </div>

      {/* Feature 2 */}
      <div
        class="bg-gray-50 dark:bg-slate-900 p-8 rounded-3xl flex flex-col items-center text-center group hover:bg-white dark:hover:bg-slate-800 hover:shadow-2xl hover:shadow-red-500/10 transition-all duration-500 border border-gray-100 dark:border-white/5"
      >
        <div class="w-full h-48 mb-8 overflow-hidden rounded-2xl">
          <img
            src="./2.webp"
            alt="Tecnología"
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
          />
        </div>
        <h4 class="text-2xl font-bold mb-2 text-black dark:text-white">
          TECNOLOGÍA
        </h4>
        <p
          class="text-[#EF4444] text-sm font-semibold mb-6 uppercase tracking-wider"
        >
          Conectividad Inteligente
        </p>
        <ul
          class="text-gray-600 dark:text-gray-400 space-y-3 text-left w-full font-light"
        >
          <li class="flex items-start gap-2">
            <span class="text-[#EF4444] mt-1">●</span>
            Pantalla LED de 9" Alta Definición
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#EF4444] mt-1">●</span>
            Volante multifunción deportivo
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#EF4444] mt-1">●</span>
            Climatizador automático inteligente
          </li>
        </ul>
      </div>

      {/* Feature 3 */}
      <div
        class="bg-gray-50 dark:bg-slate-900 p-8 rounded-3xl flex flex-col items-center text-center group hover:bg-white dark:hover:bg-slate-800 hover:shadow-2xl hover:shadow-red-500/10 transition-all duration-500 border border-gray-100 dark:border-white/5"
      >
        <div class="w-full h-48 mb-8 overflow-hidden rounded-2xl">
          <img
            src="./3.webp"
            alt="Seguridad"
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
          />
        </div>
        <h4 class="text-2xl font-bold mb-2 text-black dark:text-white">
          SEGURIDAD
        </h4>
        <p
          class="text-[#EF4444] text-sm font-semibold mb-6 uppercase tracking-wider"
        >
          Protección Total
        </p>
        <ul
          class="text-gray-600 dark:text-gray-400 space-y-3 text-left w-full font-light"
        >
          <li class="flex items-start gap-2">
            <span class="text-[#EF4444] mt-1">●</span>
            Sistemas de frenado ABS + EBD
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#EF4444] mt-1">●</span>
            Control de estabilidad avanzado
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#EF4444] mt-1">●</span>
            Estructura de alta resistencia
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .car-image.opacity-100 {
    opacity: 1;
    transform: scale(1) translateX(0);
  }

  .color-btn.active-color {
    border-color: #ef4444; /* Rojo */
    transform: scale(1.1);
  }
</style>

<script>
  const setupColorPicker = () => {
    const colorButtons = document.querySelectorAll(".color-btn");
    const cars = {
      white: document.getElementById("white-car"),
      red: document.getElementById("red-car"),
      black: document.getElementById("black-car"),
    };

    colorButtons.forEach((button) => {
      button.addEventListener("click", () => {
        colorButtons.forEach((btn) => {
          btn.classList.remove("active-color", "shadow-lg");
        });

        button.classList.add("active-color");
        button.classList.add("shadow-lg");

        const selectedColor = button.id;
        Object.entries(cars).forEach(([color, img]) => {
          if (img) {
            if (color === selectedColor) {
              img.classList.add("opacity-100", "scale-100");
              img.classList.remove("opacity-0", "scale-95", "translate-x-8");
            } else {
              img.classList.add("opacity-0", "scale-95", "translate-x-8");
              img.classList.remove("opacity-100", "scale-100");
            }
          }
        });
      });
    });
  };

  setupColorPicker();
  document.addEventListener("astro:after-swap", setupColorPicker);
</script>
